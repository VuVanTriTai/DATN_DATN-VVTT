# Frontend — Biến môi trường mẫu
# Sao chép file này thành .env và điền đầy đủ giá trị
# cp .env.example .env

# ── API Backend ───────────────────────────────────────────────────────────────
# URL gốc của Backend API
# Dev: http://localhost:5000/api
# Production: https://your-backend-domain.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Lấy từ: https://console.cloud.google.com
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Nhớ thêm http://localhost:3000 vào "Authorised JavaScript origins"
VITE_GOOGLE_CLIENT_ID=
