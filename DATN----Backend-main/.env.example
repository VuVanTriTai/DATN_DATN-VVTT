# Backend — Biến môi trường mẫu
# Sao chép file này thành .env và điền đầy đủ giá trị
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Lấy từ: https://www.mongodb.com/cloud/atlas
# Định dạng: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Tạo chuỗi ngẫu nhiên mạnh, VD: openssl rand -hex 64
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL của Frontend (dev: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Lấy từ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Groq LLM API ─────────────────────────────────────────────────────────────
# Lấy từ: https://console.groq.com/keys
# Hệ thống dùng nhiều key để load balancing / tránh rate limit
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=

# ── Hugging Face (Embedding) ──────────────────────────────────────────────────
# Lấy từ: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Cloudinary (Lưu trữ file / ảnh) ─────────────────────────────────────────
# Lấy từ: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Embedding ────────────────────────────────────────────────────────────────
# Số luồng xử lý embedding song song (khuyến nghị: 1-3)
EMBEDDING_CONCURRENCY=2

# ── Cloudflare R2 (Tuỳ chọn — lưu trữ thay thế) ─────────────────────────────
# Chỉ cần nếu dùng R2 thay Cloudinary
# Lấy từ: https://dash.cloudflare.com → R2 → Manage API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
